# Copy to .env and fill in. Two ways to point at an LLM:

# Option A — any OpenAI-compatible proxy/gateway
LLM_PROXY_MODEL=
LLM_PROXY_HOST=
LLM_PROXY_API_KEY=
# Reflection model GEPA uses to propose prompt rewrites (can be the same or a stronger model)
LLM_PROXY_REFLECTION_MODEL=

# Option B — OpenRouter directly (used if the proxy vars above are unset)
OPENROUTER_MODEL=
OPENROUTER_API_KEY=

# Shared
LM_MAX_TOKENS=8000
